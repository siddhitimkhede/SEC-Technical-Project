<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kioko</title>
<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{--pista:#cfe8d5;--white:#ffffff;--text:#4a4a4a;}
body{margin:0;font-family:Poppins,sans-serif;background:#fff;color:var(--text);}
#splash{position:fixed;inset:0;background:#fff;display:flex;align-items:center;justify-content:center;z-index:9999;}
#splash h1{font-family:'Great Vibes',cursive;font-size:70px;color:var(--pista);}
header{background:var(--pista);padding:15px 30px;display:flex;justify-content:space-between;align-items:center;}
.logo{font-family:'Great Vibes',cursive;font-size:32px;}
.actions{display:flex;gap:20px;font-size:14px;}
.container{padding:40px 8%;display:flex;flex-direction:column;gap:40px;}
.card{background:#fff;border-radius:18px;box-shadow:0 6px 18px rgba(0,0,0,.08);overflow:hidden;max-width:700px;margin:auto;}
.card img{width:100%;height:auto;max-height:420px;object-fit:contain;background:#f8f8f8;}
.card-content{padding:20px;}
.price{color:#6fa987;font-size:18px;margin:10px 0;font-weight:500;}
button{background:var(--pista);border:none;padding:10px 18px;border-radius:8px;cursor:pointer;}
footer{text-align:center;padding:25px;color:#777;font-size:13px;}
</style>
</head>
<body>

<div id="splash"><h1>Kioko</h1></div>

<header>
  <div class="logo">Kioko</div>
  <div class="actions">👤 Account | 🛒 Cart (<span id="cartCount">0</span>)</div>
</header>

<section class="container">

<div class="card">
<img src="data:image/jpeg;base64,">
<div class="card-content">
<h2>Pink Ribbon iPhone Case</h2>
<p>Soft aesthetic bow design with transparent finish. Lightweight yet protective.</p>
<div class="price">₹599</div>
<button onclick="addToCart()">Add to Cart</button>
</div></div>

<div class="card">
<img src="data:image/jpeg;base64,">
<div class="card-content">
<h2>Minimal Bow iPhone Case</h2>
<p>Delicate pastel bow pattern with glossy premium look.</p>
<div class="price">₹549</div>
<button onclick="addToCart()">Add to Cart</button>
</div></div>

<div class="card">
<img src="data:image/jpeg;base64,">
<div class="card-content">
<h2>Classic Ribbon iPhone Case</h2>
<p>Neutral ribbon artwork perfect for minimal aesthetic style.</p>
<div class="price">₹579</div>
<button onclick="addToCart()">Add to Cart</button>
</div></div>

<div class="card">
<img src="data:image/jpeg;base64,">
<div class="card-content">
<h2>Watermelon Charm iPhone Case</h2>
<p>Cute 3D fruit design with soft silicone protection.</p>
<div class="price">₹629</div>
<button onclick="addToCart()">Add to Cart</button>
</div></div>

<div class="card">
<img src="data:image/png;base64,

">
<div class="card-content">
<h2>Ribbon Aesthetic iPad Cover</h2>
<p>Premium foldable stand cover with pastel ribbon theme.</p>
<div class="price">₹1299</div>
<button onclick="addToCart()">Add to Cart</button>
</div></div>

<div class="card">
<img src="data:image/jpeg;base64,">
<div class="card-content">
<h2>Elegant Bow iPad Case</h2>
<p>Stylish protection with soft inner lining.</p>
<div class="price">₹1199</div>
<button onclick="addToCart()">Add to Cart</button>
</div></div>

<div class="card">
<img src="data:image/webp;base64,">
<div class="card-content">
<h2>Pastel Bow AirPods Case</h2>
<p>Glossy hard shell case with keyring holder.</p>
<div class="price">₹399</div>
<button onclick="addToCart()">Add to Cart</button>
</div></div>

<div class="card">
<img src="data:image/jpeg;base64,">
<div class="card-content">
<h2>Cream Aesthetic AirPods Cover</h2>
<p>Minimal soft-touch finish with adorable charm.</p>
<div class="price">₹379</div>
<button onclick="addToCart()">Add to Cart</button>
</div></div>

</section>

<footer>© 2026 Kioko — Soft Aesthetic Accessories</footer>

<script>
window.addEventListener("load",()=>{setTimeout(()=>{document.getElementById("splash").style.display="none";},2000);});
let cart=0;
function addToCart(){cart++;document.getElementById("cartCount").innerText=cart;}
</script>

</body>
</html>
